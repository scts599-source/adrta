# Flask Configuration
SECRET_KEY=your-secret-key-here-generate-a-random-one

# Database (Render will provide DATABASE_URL automatically)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# CORS Origins (comma-separated for multiple origins)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Email Service (Brevo/Sendinblue)
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=your-email@example.com
BREVO_TEMPLATE_ID=2
BREVO_ORDER_CONFIRMATION_TEMPLATE=3
BREVO_SHIPPING_UPDATE_TEMPLATE=4
BREVO_DELIVERY_CONFIRMATION_TEMPLATE=5

# SMS Service (Fast2SMS)
FAST2SMS_API_KEY=your-fast2sms-api-key

# Team Portal Authentication
TEAM_PORTAL_USER=admin
TEAM_PORTAL_PASSWORD=your-secure-password

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Redis (optional, for rate limiting)
# REDIS_URL=redis://localhost:6379

# Environment
ENVIRONMENT=production
FLASK_DEBUG=0